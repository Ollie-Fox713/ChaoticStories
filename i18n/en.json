  "faq.back": "BACK",
  "faq.systemLabel": "CHAOTIC PORTAL SYSTEM",
  "faq.title": "FREQUENTLY ASKED QUESTIONS",
  "faq.subtitle": "INTEL DATABASE — CLEARANCE LEVEL: PUBLIC",
  "faq.footer": "KNOWLEDGE BASE v1.0 — ALL DATA VERIFIED",
  "faq.categories.gettingStarted": "GETTING STARTED",
  "faq.categories.scanning": "SCANNING & COLLECTION",
